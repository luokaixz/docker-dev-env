[mysqld]
lower_case_table_names=1
port=3306

# 字符编码设置
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci
init_connect='SET NAMES utf8mb4'

# 配置服务器的服务号，具备日后需要集群做准备
server-id=1
binlog_format="ROW"
# 开启 Binlog 并写明存放日志的位置
log_bin = /var/log/mysql/bin-log
# 指定索引文件的位置
log_bin_index = /var/log/mysql/bin-log.index
# 设置清理超过30天的日志，以免日志堆积造过多成服务器内存爆满
binlog_expire_logs_seconds = 2592000

# 开启慢查询
slow_query_log = 1
slow_query_log_file = /var/log/mysql/long-query-log
# 慢查询时间，默认为10s
long_query_time = 10

# 设置东八区时区
default-time_zone = '+8:00'

bind-address = 0.0.0.0

# ===== AI 开发最低内存占用配置（追加）=====
# InnoDB 缓冲池 - 最小可设 5M（MySQL 8.0 支持）
innodb_buffer_pool_size = 5M
# 日志缓冲 - 最小 1M
innodb_log_buffer_size = 1M
# MyISAM 键缓冲 - 最小 8K，这里给 256K
key_buffer_size = 256K
# 最大连接数 - 开发环境 3 个足矣
max_connections = 3
# 线程缓存 - 对应连接数
thread_cache_size = 1
# 表缓存 - 最小化
table_open_cache = 16
table_definition_cache = 16
# 临时表内存限制 - 最小 1M
tmp_table_size = 1M
max_heap_table_size = 1M
# 关闭 Performance Schema（省内存）
performance_schema = OFF
# 跳过 DNS 反向解析
skip_name_resolve
# 打开文件数限制
open_files_limit = 256
# 关闭二进制日志（如必须保留 binlog，请注释下面两行）
# 说明：binlog 会额外占用内存和磁盘，AI 开发建议关闭；若需保留，则维持原有配置。
disable-log-bin
skip-log-bin
